# BloomTrade — Plantilla de variables de entorno
#
# Uso:
#   cp .env.example .env
#   # editar .env con valores reales (NUNCA commitear .env)
#
# Regla CLAUDE.md #24: ningún secreto va a Git. .env está en .gitignore.

# ─── Spring profile activo ─────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=bloomtrade
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bloomtrade

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Sin password en dev local. En prod definir REDIS_PASSWORD.
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=replace-with-64-byte-base64-secret
JWT_ACCESS_TTL_MINUTES=15
# JWT_REFRESH_SECRET removido por HU-F02 D18 — el refresh token será opaco (no JWT) cuando se
# implemente la mini-HU HU-F0X-token-rotation-logout post-MVP.

# ─── Stripe (modo test) — HU-F06 ───────────────────────────────────────────────
# Usar Restricted API Key (RAK, prefijo rk_), NO el Secret Key (sk_) — best practice de Stripe.
# Crear en https://dashboard.stripe.com/test/apikeys con permisos mínimos:
#   Customers (write), Checkout Sessions (write), Subscriptions (read), Billing Portal Sessions (write).
STRIPE_API_KEY=rk_test_replace_with_restricted_key
# Tomar del output de `stripe listen --forward-to localhost:8080/api/v1/webhooks/stripe`.
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Crear ambos Prices en https://dashboard.stripe.com/test/prices (USD $12/mo, USD $120/yr).
STRIPE_PRICE_MONTHLY=price_replace_me
STRIPE_PRICE_YEARLY=price_replace_me

# ─── Twilio (SMS / WhatsApp) ───────────────────────────────────────────────────
# Obtener en https://console.twilio.com
TWILIO_ACCOUNT_SID=AC_replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=+10000000000

# ─── Alpaca (paper trading) ────────────────────────────────────────────────────
# Obtener en https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=replace_me
ALPACA_API_SECRET=replace_me
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Polygon.io (market data) ──────────────────────────────────────────────────
# Obtener en https://polygon.io/dashboard/api-keys (free tier suficiente para MVP)
POLYGON_API_KEY=replace_me

# ─── Email ─────────────────────────────────────────────────────────────────────
# Dev: MailHog captura todo en :8025, no requiere credenciales.
MAIL_FROM=no-reply@bloomtrade.local
# Base URL del frontend para los links de los emails (HU-F01: botón "Iniciar sesión").
APP_BASE_URL=http://localhost:5173
